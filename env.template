# ============================================
# Cấu hình Kafka (đồng bộ checkin/checkout lên HUB, consumer nhận CHECKIN_HUB_INFO)
# ============================================
# Bật Kafka: set KAFKA_BOOTSTRAP_SERVERS (mặc định localhost:9092 khi set).
# Nhiều broker: cách nhau bằng dấu phẩy (có thể có khoảng trắng, sẽ bị trim).
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092
# Topic producer: gửi checkin + checkout lên HUB. Mặc định: topics.hub.trans.online (DEFAULT_TOPIC_HUB_TRANS)
# KAFKA_TOPIC_TRANS_HUB_ONLINE=topics.hub.trans.online
# Số partition cố định cho topic producer trên (vd 4). Nếu set thì không gọi list_topics, giảm rủi ro timeout trên cluster lớn.
# KAFKA_TOPIC_TRANS_PARTITION_COUNT=4
# Chỉ định partition cố định khi produce (0-based). Nếu set thì mọi message gửi vào partition này, bỏ qua chọn theo key (vd 0, 1, 2).
# KAFKA_TOPIC_TRANS_FIXED_PARTITION=0
# Topic consumer: nhận đồng bộ checkin từ HUB về BOO (mặc định: topics.hub.checkin.trans.online)
# KAFKA_TOPIC_CHECKIN_HUB_ONLINE=topics.hub.checkin.trans.online
# Số partition cố định cho topic consumer trên (ví dụ 3). Nếu set thì bỏ qua auto-detect, tránh log ERROR khi probe partition không tồn tại.
# KAFKA_TOPIC_CHECKIN_PARTITION_COUNT=3
# Bật Kafka consumer (nhận CHECKIN_HUB_INFO từ HUB). 1/true/yes = bật; mặc định = cùng trạng thái với Kafka enabled
# KAFKA_CONSUMER_ENABLED=true
# File lưu offset consumer (tùy chọn). Nếu không set thì dùng offset mặc định của Kafka
# KAFKA_CONSUMER_OFFSET_FILE=./data/kafka_consumer_offset.json
# HA: Key KeyDB cho leader lock — chỉ một pod chạy consumer (mặc định: kafka_consumer_leader)
# KAFKA_CONSUMER_LEADER_LOCK_KEY=kafka_consumer_leader
# HA: TTL (giây) của leader lock; renew trước khi hết TTL (mặc định: 60)
# KAFKA_CONSUMER_LEADER_LOCK_TTL_SECS=60
# Username cho SASL PLAIN authentication (tùy chọn, nếu không set thì không dùng authentication)
# SECURITY: Replace with your actual Kafka username
# BẢO MẬT: Thay thế bằng Kafka username thực tế của bạn
# KAFKA_USERNAME=your_kafka_username
# Password cho SASL PLAIN authentication (tùy chọn, chỉ dùng khi KAFKA_USERNAME được set)
# SECURITY: Replace with your actual Kafka password
# BẢO MẬT: Thay thế bằng Kafka password thực tế của bạn
# KAFKA_PASSWORD=your_kafka_password
# Timeout (giây) mỗi lần thử kết nối Kafka lúc khởi tạo nền (mặc định 15)
# KAFKA_INIT_TIMEOUT_SECS=15
# Khoảng cách (giây) giữa các lần retry khi init thất bại (mặc định 10)
# KAFKA_INIT_RETRY_INTERVAL_SECS=10
# Phiên bản dữ liệu event (mặc định: 1.0)
# KAFKA_DATA_VERSION=1.0
# Request timeout ms cho mỗi thao tác Kafka (partition + produce). Cũng dùng để phát hiện kết nối treo (mặc định: 5000)
# KAFKA_REQUEST_TIMEOUT_MS=5000
# Số lần retry khi gửi thất bại (mặc định 10); Kafka offline sẽ retry đến khi thành công hoặc hết số lần
# KAFKA_RETRIES=10
# Delay (ms) trước retry lần đầu (mặc định 1000)
# KAFKA_RETRY_INITIAL_DELAY_MS=1000
# Delay tối đa (ms) giữa các lần retry - exponential backoff cap (mặc định 60000)
# KAFKA_RETRY_MAX_DELAY_MS=60000
# Sức chứa hàng đợi Kafka (số event tối đa chờ gửi). Khi đầy bỏ event cũ nhất, giữ event mới (mặc định 10000)
# KAFKA_QUEUE_CAPACITY=10000
# Số record gửi một lần lên Kafka (batch). Càng lớn càng ít round-trip, dữ liệu lên server nhanh hơn (mặc định 50)
# KAFKA_SEND_BATCH_SIZE=50
# Chu kỳ kiểm tra kết nối còn sống (giây). 0 = tắt. Nên bật khi Kafka qua nhiều lớp mạng để phát hiện server down/restart (mặc định 60)
# KAFKA_LIVENESS_CHECK_INTERVAL_SECS=60

# ============================================
# Cấu hình Logging (file + level)
# ============================================
# Thư mục lưu file log (mặc định: ./logs)
# LOG_DIR=./logs
# Tên file log không kèm extension (mặc định: rct → rct-VETC-2026-02-23.log)
# LOG_FILE_NAME=rct
# Kích thước tối đa mỗi file log - bytes (mặc định: 2097152 = 2MB)
# LOG_MAX_FILE_SIZE=2097152
# Số ngày giữ log trước khi xóa (mặc định: 30)
# LOG_RETENTION_DAYS=30
# Mức log: trace, debug, info, warn, error (mặc định: info)
# LOG_LEVEL=info
# Bật ghi file *-debug-*.log (mọi log mức debug trở lên) để trace. 1|true|yes = bật (mặc định: tắt)
# LOG_DEBUG_FILE=1