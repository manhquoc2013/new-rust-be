# Cấu hình Port lắng nghe (tùy chọn, mặc định: 8080)
PORT_LISTEN=9001

# Ticket_id từ DB (prefix + suffix 3 chữ số): suffix tối đa 1..999 (mặc định 999). ticket_id = prefix * 1000 + suffix.
# TICKET_ID_SUFFIX_MAX=999
# Khi suffix đạt ngưỡng này thì prefetch sequence tiếp theo từ DB (mặc định 980; phải <= TICKET_ID_SUFFIX_MAX).
# TICKET_ID_PREFETCH_THRESHOLD=980

# Giới hạn số kết nối đồng thời tối đa (0 = không giới hạn).
# Nếu không set: mặc định theo CPU = min(10000, max(500, số_lõi*200)); fallback 2000.
# Maximum concurrent connections (0 = unlimited). When unset: default from CPU = min(10000, max(500, cores*200)); fallback 2000.
MAX_CONNECTIONS=1000

# Timeout ép đóng nếu chưa handshake (giây). 0 = tắt: không ép đóng khi client vẫn kết nối; dùng TCP keepalive để phát hiện kết nối half-open (mặc định: 0).
# Handshake timeout (seconds). 0 = disabled: rely on TCP keepalive to detect dead/half-open connections (default: 0).
# HANDSHAKE_TIMEOUT_SECONDS=0

# TCP keepalive trên server (phát hiện kết nối half-open: client/router đã ngắt nhưng server chưa biết).
# TCP_KEEPALIVE_IDLE_SECONDS: thời gian idle (giây) trước khi gửi probe đầu tiên (0 = chỉ bật SO_KEEPALIVE, dùng mặc định OS; mặc định: 60).
# TCP_KEEPALIVE_INTERVAL_SECONDS: khoảng cách giữa các probe (giây; mặc định: 10).
# TCP_KEEPALIVE_RETRIES: số lần probe không phản hồi trước khi đóng (Linux TCP_KEEPCNT; mặc định: 3).
# TCP_KEEPALIVE_IDLE_SECONDS=60
# TCP_KEEPALIVE_INTERVAL_SECONDS=10
# TCP_KEEPALIVE_RETRIES=3

# Timeout cho socket read operations (giây, 0 = tắt timeout, mặc định: 300 = 5 phút)
# Nếu client không gửi dữ liệu trong khoảng thời gian này, connection sẽ bị đóng
# Socket read timeout (seconds, 0 = disabled, default: 300 = 5 minutes)
# If client doesn't send data within this time, connection will be closed
SOCKET_READ_TIMEOUT_SECONDS=300

# Timeout cho idle connections trước khi cleanup (giây, mặc định: 300 = 5 phút)
# Connection idle timeout before cleanup (seconds, default: 300 = 5 minutes)
CONNECTION_IDLE_TIMEOUT_SECONDS=300

# Khoảng thời gian kiểm tra dead connections (giây, mặc định: 30)
# Interval to check for dead connections (seconds, default: 30)
DEAD_CONNECTION_CHECK_INTERVAL_SECONDS=30

# Danh sách IP/dải IP bị từ chối kết nối (denylist), phân cách bằng dấu phẩy.
# Hỗ trợ: IP đầy đủ (10.10.10.10), prefix với wildcard (10.10.*, 10.*). Kết nối từ IP khớp bị đóng ngay, không ghi log.
# IP denylist (comma-separated). Supports: full IP (10.10.10.10), wildcard prefix (10.10.*, 10.*). Matching IPs are rejected immediately, no log.
# IP_DENYLIST=10.10.*,192.168.1.100

# Chỉ chấp nhận bản tin FE 8-byte (request_id/session_id i64). Khi bật: bản tin 4-byte bị từ chối, trả về status 16 (FE_MESSAGE_FORMAT_4BYTE_REJECTED).
# FE_REQUIRE_8BYTE_IDS: 1/true/yes = chỉ nhận 8-byte; mặc định = false (nhận cả 4-byte và 8-byte).
# FE_REQUIRE_8BYTE_IDS=false

# Bỏ qua kiểm tra user/pass khi FE kết nối (tùy chọn, mặc định: false = kiểm tra user/pass hợp lệ)
# Set 1/true/yes để bypass (chỉ dùng dev/test). Bảo mật: không bật trong production.
# Bypass FE connect auth check (optional, default: false = validate user/pass)
CONNECT_BYPASS_AUTH=false

# BECT checkout: bỏ qua kiểm tra subscriber/account tồn tại và active (tùy chọn, mặc định: false)
# Set 1/true/yes để bypass. Khi bypass: không trả 100 (SUBSCRIBER_NOT_FOUND), 102 (ACCOUNT_IS_NOT_ACTIVE).
# BECT_SKIP_ACCOUNT_CHECK=false

# BECT check-in lane IN: số dư tối thiểu (VNĐ). Khi > 0: kiểm tra available_balance >= giá trị này; không đủ trả 104 (ACCOUNT_NOT_ENOUGH_MONEY). 0 = tắt kiểm tra. Đồng bộ Java getMinimumBalance/checkinCloseIn.
# BECT_MINIMUM_BALANCE_CHECKIN=0
# Khi true: chỉ áp dụng kiểm tra min balance khi check-in lane IN nếu trạm mở (toll_type O). Java: hold+min chỉ khi stationLane ∈ {OPEN,HOLD,REFUND,ONLY_REFUND,CAM}. Xem docs/BECT_LANETYPE_MIN_BALANCE.md.
# BECT_MINIMUM_BALANCE_CHECKIN_OPEN_ONLY=false

# Tính phí: khi không tìm thấy bảng giá hoặc cung đường, vẫn cho phép tính phí 0đ và tiếp tục (VDTC/VETC/BECT checkin).
# Set 1/true/yes để bật. Mặc định: false (trả NOT_FOUND_PRICE_INFO khi thiếu giá/route).
# Toll fee bypass: when no price table or route found, allow fee 0 and continue (default: false).
# ALLOW_ZERO_FEE_WHEN_NO_PRICE_OR_ROUTE=false

# Khoảng thời gian reload cache định kỳ (giây, tùy chọn, mặc định: 1800 = 30 phút)
# Cache sẽ tự động reload price và toll_lane data từ database sau mỗi khoảng thời gian này
CACHE_RELOAD_INTERVAL_SECONDS=1800

# ============================================
# ETDR (Event-driven retry / cleanup)
# ============================================
# Chu kỳ dọn ETDR cache (giây, tùy chọn, mặc định: 3600 = 1 giờ)
ETDR_CLEANUP_INTERVAL_SECONDS=3600
# Khoảng thời gian giữa các lần retry ghi ETDR vào DB (giây, mặc định: 30)
ETDR_RETRY_INTERVAL_SECONDS=30
# Số lần retry tối đa khi ghi ETDR thất bại (mặc định: 10)
ETDR_MAX_RETRY_COUNT=10

# Danh sách prefix eTag của Boox1 (VETC) - phân cách bằng dấu phẩy (bắt buộc)
BOOX1_PREFIX_LIST=3416214B88,89301100013

