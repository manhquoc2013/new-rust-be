# Example secret file - DO NOT commit this with real values
# SECURITY WARNING: This is an EXAMPLE file. NEVER commit real passwords or keys!
# CẢNH BÁO BẢO MẬT: Đây là file VÍ DỤ. KHÔNG BAO GIỜ commit passwords hoặc keys thật!

# Create actual secret using kubectl (RECOMMENDED):
# kubectl create secret generic rust-core-be-secrets \
#   --from-literal=key-enc='YOUR_KEY_ENC' \
#   --from-literal=vdtc-username='YOUR_VDTC_USERNAME' \
#   --from-literal=vdtc-password='YOUR_VDTC_PASSWORD' \
#   --from-literal=vdtc-key-enc='YOUR_VDTC_KEY_ENC' \
#   --from-literal=keydb-url='redis://username:password@host:port' \
#   --namespace=rust-core-be

# Or use sealed-secrets, external-secrets, Vault, or other secret management tools
# Hoặc sử dụng sealed-secrets, external-secrets, Vault, hoặc các công cụ quản lý secret khác

apiVersion: v1
kind: Secret
metadata:
  name: rust-core-be-secrets
  namespace: rust-core-be
  labels:
    app: rust-core-be
type: Opaque
stringData:
  # Application encryption key
  # Khóa mã hóa ứng dụng
  key-enc: "REPLACE_WITH_YOUR_KEY_ENC"
  
  # VDTC connection credentials
  # Thông tin đăng nhập kết nối VDTC
  vdtc-username: "REPLACE_WITH_YOUR_VDTC_USERNAME"
  vdtc-password: "REPLACE_WITH_YOUR_VDTC_PASSWORD"
  vdtc-key-enc: "REPLACE_WITH_YOUR_VDTC_KEY_ENC"
  
  # Cache System (KeyDB/Redis) connection URL
  # URL kết nối Cache System (KeyDB/Redis)
  # Format: redis://[username]:[password]@[host]:[port] or redis://[host]:[port]
  keydb-url: "REDIS_URL"
